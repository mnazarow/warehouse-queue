# Copy to .env and fill in. Do NOT commit the real .env.
# cp .env.example .env

# Public domain (A/AAAA record must already point at this server)
DOMAIN=example.com
# Email for Let's Encrypt expiry notices
CERTBOT_EMAIL=admin@example.com

# Express session secret — generate a long random value, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# PostgreSQL credentials (used by the postgres service AND seeded into the app)
POSTGRES_DB=warehouse
POSTGRES_USER=warehouse
POSTGRES_PASSWORD=change-me-strong-password

# Production only: the CI-built image to run instead of building locally.
# Set on the server so `docker compose pull app` works. Must be lowercase.
# APP_IMAGE=ghcr.io/your-github-user/warehouse-queue:latest
